{
    "name": "emiliosh/autofirma-plugin",
    "description": "FilamentPHP plugin para integración con AutoFirma (firma electrónica, España)",
    "keywords": [
        "filament",
        "filamentphp",
        "autofirma",
        "firma-electronica",
        "electronic-signature",
        "dni-electronico",
        "laravel",
        "plugin"
    ],
    "homepage": "https://github.com/emiliosh/autofirma-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Emiliosh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Emiliosh\\AutofirmaPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emiliosh\\AutofirmaPlugin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Emiliosh\\AutofirmaPlugin\\AutofirmaPluginServiceProvider"
            ],
            "aliases": {
                "Autofirma": "Emiliosh\\AutofirmaPlugin\\Facades\\Autofirma"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
